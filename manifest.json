{
  "manifest_version": 3,
  "name": "Screen Pet - 화면 펫",
  "version": "1.0.0",
  "description": "화면을 뛰어다니는 귀여운 펫 친구 🐱 클릭해서 드래그할 수도 있어요!",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
